{
  "name": "token-scope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "refresh-cache": "jiti scripts/refresh-cache.ts",
    "dev": "pnpm refresh-cache && next dev -p 3300 -H 127.0.0.1",
